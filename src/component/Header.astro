---
import { getCollection } from "astro:content";

// 获取所有文章
const posts = await getCollection("posts");

// 提取 category 去重
const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
---

<header class="site-header">
  <div class="nav-container">
    <a href="/myblog/" class="logo">我的博客</a>

    <nav class="nav-links">

      <!-- 自动生成专栏 -->
      <div class="dropdown">
        <a class="dropdown-title">专题</a>

        <div class="dropdown-menu">
          {categories.map((category) => (
            <a href={`/myblog/columns/${encodeURIComponent(category)}`}>{category}</a>
          ))}
        </div>
      </div>

      <a href="/archive">归档</a>
      <a href="/tags">标签</a>
      <a href="https://github.com/SakanactionQAQ" target="_blank" rel="noopener">GitHub</a>

    </nav>
  </div>
</header>